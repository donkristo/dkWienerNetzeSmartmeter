{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug current test file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-o",
                "addopts=",
                "${file}"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPYCACHEPREFIX": "/tmp/wnsm_pycache"
            },
            "justMyCode": false
        },
        {
            "name": "Attach local Python",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "${workspaceFolder}"
                }
            ],
            "justMyCode": false
        },
        {
            "name": "Attach Home Assistant custom component",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "homeassistant.local",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/custom_components/wnsm",
                    "remoteRoot": "/config/custom_components/wnsm"
                }
            ],
            "justMyCode": false
        }
    ]
}
